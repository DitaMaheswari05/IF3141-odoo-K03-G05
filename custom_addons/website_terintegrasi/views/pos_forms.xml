<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_laporan_form" model="ir.ui.view">
        <field name="name">pos.laporan.form</field>
        <field name="model">pos.laporan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="id_laporan"/>
                        <field name="tanggal"/>
                        <field name="id_pengguna"/>
                    </group>
                    <notebook>
                        <page string="Aktivitas &amp; Laporan">
                            <field name="isi_laporan" placeholder="Masukkan laporan aktivitas harian..."/>
                        </page>
                        <page string="Kendala Lapangan">
                            <field name="kendala" placeholder="Deskripsikan kendala operasional..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_rekap_form" model="ir.ui.view">
        <field name="name">pos.rekap.form</field>
        <field name="model">pos.rekap</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="id_rekap"/>
                        <field name="tanggal"/>
                        <field name="id_pengguna"/>
                        <field name="total_pemasukan"/>
                    </group>
                    <notebook>
                        <page string="Validasi Laporan Operasional">
                            <field name="laporan_ids">
                                <tree editable="bottom">
                                    <field name="id_laporan"/>
                                    <field name="tanggal"/>
                                    <field name="kendala"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>