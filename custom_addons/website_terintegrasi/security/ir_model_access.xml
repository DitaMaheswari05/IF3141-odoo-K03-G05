<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Access rights defined in XML so we can reference ir.model records by XML id -->
    <record id="access_pos_pengguna" model="ir.model.access">
        <field name="name">access_pos_pengguna</field>
        <field name="model_id" ref="model_pos_pengguna"/>
        <field name="group_id" eval="False"/>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
    </record>

